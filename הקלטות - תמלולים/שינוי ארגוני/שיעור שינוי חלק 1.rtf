\u1489 \u1493 \u1514  \u1500 \u1492 \u1513 \u1514 \u1504 \u1493 \u1514  \u1499 \u1491 \u1497  \u1500 \u1513 \u1512 \u1493 \u1491 . \u1502 \u1500 \u1489 \u1491  \u1511 \u1493 \u1513 \u1497  \u1488 \u1493  \u1502 \u1513 \u1489 \u1512 , \u1500 \u1508 \u1506 \u1502 \u1497 \u1501  \u1488 \u1504 \u1495 \u1504 \u1493  \u1508 \u1513 \u1493 \u1496  \u1502 \u1490 \u1500 \u1497 \u1501  \u1492 \u1494 \u1491 \u1502 \u1504 \u1493 \u1514  \u1513 \u1504 \u1511 \u1512 \u1488 \u1514 \u1492  \u1506 \u1500  \u1491 \u1512 \u1499 \u1504 \u1493 . \u1492 \u1497 \u1489 \u1496 \u1497 \u1501  \u1513 \u1492 \u1501  \u1496 \u1499 \u1504 \u1493 \u1500 \u1493 \u1490 \u1497 \u1497 \u1501  \u1493 \u1495 \u1491 \u1513 \u1497 \u1501  \u1493 \u1502 \u1488 \u1508 \u1513 \u1512 \u1497 \u1501  \u1500 \u1504 \u1493  \u1508 \u1514 \u1495  \u1495 \u1491 \u1513 . \u1488  \u1513  \u1495 \u1491 \u1513  \u1513 \u1504 \u1508 \u1514 \u1495  \u1489 \u1508 \u1504 \u1497 \u1504 \u1493 , \u1496 \u1499 \u1504 \u1493 \u1500 \u1493 \u1490 \u1497 \u1492  \u1493 \u1492 \u1494 \u1491 \u1502 \u1504 \u1493 \u1497 \u1493 \u1514  \u1513 \u1500  \u1513 \u1493 \u1511  \u1492 \u1501  \u1491 \u1493 \u1490 \u1502 \u1492  \u1500 \u1499 \u1498  \u1513 \u1513 \u1497 \u1504 \u1493 \u1497  \u1497 \u1499 \u1493 \u1500  \u1500 \u1492 \u1514 \u1512 \u1495 \u1513  \u1489 \u1500 \u1497  \u1513 \u1497 \u1492 \u1497 \u1492  \u1500 \u1504 \u1493  \u1488 \u1497 \u1494 \u1513 \u1492 \u1493  \u1511 \u1493 \u1513 \u1497  \u1488 \u1493  \u1502 \u1513 \u1493 \u1512 , \u1488 \u1500 \u1488  \u1512 \u1511  \u1502 \u1511 \u1493 \u1512 \u1495  \u1492 \u1492 \u1494 \u1491 \u1502 \u1504 \u1493 \u1514  \u1506 \u1510 \u1502 \u1492 .
