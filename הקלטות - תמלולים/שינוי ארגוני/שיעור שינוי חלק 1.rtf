\f0\b \cb3 \uc0\u1499 \u1513 \u1502 \u1491 \u1493 \u1489 \u1512  \u1489 \u1506 \u1510 \u1501  \u1489 \u1502 \u1493 \u1510 \u1512 \u1497 \u1501  \u1493 \u1513 \u1497 \u1512 \u1493 \u1514 \u1497 \u1501 , \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1491 \u1489 \u1512 \u1497 \u1501  \u1506 \u1500  \u1513 \u1497 \u1504 \u1493 \u1497  \u1489 \u1508 \u1497 \u1514 \u1493 \u1495  \u1513 \u1500  \u1502 \u1493 \u1510 \u1512 \u1497 \u1501  \u1493 \u1513 \u1497 \u1512 \u1493 \u1514 \u1497 \u1501  \u1513 \u1499 \u1489 \u1512  \u1511 \u1497 \u1497 \u1502 \u1497 \u1501 . \u1492 \u1493 \u1505 \u1508 \u1492  \u1513 \u1500  \u1502 \u1493 \u1510 \u1512 \u1497 \u1501 , \u1508 \u1497 \u1514 \u1493 \u1495  \u1513 \u1500  \u1502 \u1493 \u1510 \u1512 \u1497 \u1501  \u1493 \u1488 \u1508 \u1497 \u1500 \u1493  \u1513 \u1497 \u1512 \u1493 \u1514 \u1497 \u1501  \u1504 \u1493 \u1505 \u1508 \u1497 \u1501 . \u1513 \u1497 \u1504 \u1493 \u1497 \u1497 \u1501  \u1489 \u1514 \u1495 \u1493 \u1502 \u1497 \u1501  \u1492 \u1508 \u1497 \u1494 \u1497 \u1497 \u1501  \u1492 \u1501  \u1499 \u1493 \u1500 \u1500 \u1497 \u1501  \u1489 \u1506 \u1510 \u1501  \u1513 \u1497 \u1504 \u1493 \u1497 \u1497 \u1501  \u1496 \u1499 \u1504 \u1493 \u1500 \u1493 \u1490 \u1497 \u1497 \u1501 , \u1502 \u1506 \u1512 \u1499  \u1493 \u1514  \u1513 \u1500  \u1502 \u1497 \u1491 \u1506  \u1495 \u1491 \u1513 \u1493 \u1514 , \u1502 \u1499 \u1493 \u1504 \u1493 \u1514  \u1495 \u1491 \u1513 \u1493 \u1514  \u1493 \u1488 \u1508 \u1497 \u1500 \u1493  \u1513 \u1497 \u1504 \u1493 \u1497  \u1489 \u1502 \u1489 \u1504 \u1497 \u1501 , \u1489 \u1502 \u1489 \u1504 \u1497 \u1501  \u1506 \u1510 \u1502 \u1501 , \u1495 \u1493 \u1502 \u1512 \u1497 \u1501  \u1495 \u1491 \u1513 \u1497 \u1501 , \u1510 \u1497 \u1493 \u1491  \u1506 \u1494 \u1512  \u1493 \u1499 \u1493 \u1500 \u1497 . \u1513 \u1497 \u1504 \u1493 \u1497 \u1497 \u1501  \u1489 \u1502 \u1489 \u1504 \u1492  \u1492 \u1501  \u1489 \u1506 \u1510 \u1501  \u1513 \u1497 \u1504 \u1493 \u1497 \u1497 \u1501  \u1513 \u1502 \u1497 \u1497 \u1510 \u1512 \u1497 \u1501  \u1502 \u1489 \u1504 \u1497 \u1501  \u1495 \u1491 \u1513 \u1497 \u1501  \'96 \u1502 \u1497 \u1494 \u1493 \u1490 \u1497 \u1501 , \u1513 \u1493 \u1514 \u1508 \u1493 \u1497 \u1493 \u1514 , \u1495 \u1489 \u1512 \u1493 \u1514  \u1489 \u1514 , \u1508 \u1497 \u1494 \u1493 \u1512  \u1490 \u1497 \u1488 \u1493 \u1490 \u1512 \u1508 \u1497  \u1502 \u1495 \u1493 \u1491 \u1513 , \u1488  \u1492 \u1512 \u1495 \u1489 \u1492  \u1488 \u1493  \u1510 \u1502 \u1510 \u1493 \u1501  \u1513 \u1500  \u1499 \u1500  \u1502 \u1497 \u1504 \u1497  \u1497 \u1495 \u1497 \u1491 \u1493 \u1514  \u1502 \u1489 \u1504 \u1497 \u1493 \u1514 , \u1489 \u1513 \u1497 \u1504 \u1493 \u1497  \u1513 \u1500  \u1514 \u1508 \u1511 \u1497 \u1491 \u1497 \u1501  \u1493 \u1502 \u1489 \u1504 \u1497 \u1501  \u1489 \u1514 \u1493 \u1498  \u1492 \u1488 \u1512 \u1490 \u1493 \u1503 . \u1513 \u1497 \u1504 \u1493 \u1497  \u1489 \u1499 \u1493 \u1495  \u1492 \u1488 \u1491 \u1501  \u1499 \u1493 \u1500 \u1500 \u1497 \u1501  \u1513 \u1497 \u1504 \u1493 \u1497  \u1489 \u1502 \u1510 \u1489 \u1514  \u1499 \u1493 \u1495  \u1488 \u1491 \u1501  \'96 \u1490 \u1497 \u1493 \u1505 , \u1508 \u1497 \u1514 \u1493 \u1512 \u1497 \u1501 , \u1513 \u1497 \u1502 \u1493 \u1513  \u1489 \u1495 \u1489 \u1512 \u1493 \u1514  \u1499 \u1493 \u1495  \u1488 \u1491 \u1501 , \u1513 \u1497 \u1502 \u1493 \u1513  \u1489 \u1506 \u1493 \u1489 \u1491 \u1497  \u1511 \u1489 \u1500 \u1503 , \u1497 \u1495 \u1505 \u1497  \u1506 \u1489 \u1493 \u1491 \u1492  \u1493 \u1499 \u1493 \u1500 \u1497 . \u1493 \u1492 \u1511 \u1496 \u1490 \u1493 \u1512 \u1497 \u1492  \u1492 \u1488 \u1495 \u1512 \u1493 \u1504 \u1492  \u1489 \u1511 \u1513 \u1512  \u1513 \u1500  \u1514 \u1495 \u1502 \u1497  \u1513 \u1497 \u1504 \u1493 \u1497  \u1492 \u1493 \u1488  \u1492 \u1513 \u1497 \u1504 \u1493 \u1497  \u1489 \u1488 \u1504 \u1513 \u1497 \u1501 . \u1513 \u1497 \u1504 \u1493 \u1497  \u1489 \u1488 \u1504 \u1513 \u1497 \u1501  \u1488 \u1508 \u1513 \u1512  \u1500 \u1511 \u1497 \u1497 \u1501  \u1493 \u1500 \u1506 \u1512 \u1493 \u1498  \u1499 \u1513 \u1502 \u1491 \u1493 \u1489 \u1512  \u1489 \u1506 \u1510 \u1501  \u1489 \u1514 \u1492 \u1500 \u1497 \u1499 \u1497 \u1501  \u1513 \u1500  \u1492 \u1491 \u1512 \u1499 \u1492  \'96 \u1492 \u1491 \u1512 \u1499 \u1492  \u1489 \u1504 \u1493 \u1513 \u1488 \u1497 \u1501  \u1513 \u1500  \u1497 \u1491 \u1506 , \u1513 \u1500  \u1511 \u1497 \u1513 \u1493 \u1512 \u1497 \u1501 , \u1502 \u1497 \u1493 \u1502 \u1504 \u1493 \u1497 \u1493 \u1514  \u1493 \u1490 \u1501  \u1513 \u1497 \u1504 \u1493 \u1497  \u1513 \u1500  \u1506 \u1502 \u1491 \u1493 \u1514 . \u1500 \u1502 \u1513 \u1500  \u1502 \u1495 \u1493 \u1489 \u1512 \u1493 \u1514  \u1488 \u1512 \u1490 \u1493 \u1504 \u1497 \u1514  \'96 \u1494 \u1492  \u1513 \u1497 \u1504 \u1493 \u1497  \u1489 \u1506 \u1510 \u1501  \u1489 \u1514 \u1492 \u1500 \u1497 \u1498  \u1513 \u1500  \u1492 \u1495 \u1497 \u1489 \u1493 \u1512  \u1500 \u1488 \u1512 \u1490 \u1493 \u1503 , \u1491 \u1512 \u1498  \u1492 \u1491 \u1512 \u1499 \u1493 \u1514  \u1493 \u1491 \u1512 \u1498  \u1495 \u1497 \u1489 \u1493 \u1512 \u1497 \u1501  \u1504 \u1493 \u1505 \u1508 \u1497 \u1501 . \u1497 \u1513 , \u1497 \u1513  \u1489 \u1506 \u1510 \u1501  \u1513 \u1500 \u1493 \u1513 \u1492  \u1505 \u1493 \u1490 \u1497  \u1513 \u1497 \u1504 \u1493 \u1497  \u1513 \u1488 \u1504 \u1497  \u1512 \u1493 \u1510 \u1492  \u1500 \u1492 \u1514 \u1497 \u1497 \u1495 \u1505  \u1488 \u1500 \u1497 \u1492 \u1501  \u1499 \u1513 \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1491 \u1489 \u1512 \u1497 \u1501  \u1506 \u1500  \u1513 \u1497 \u1504 \u1493 \u1497  \'96 \u1492 \u1492 \u1511 \u1513 \u1512  \u1492 \u1502 \u1514 \u1493 \u1499 \u1504 \u1503  \u1493 \u1492 \u1500 \u1488  \u1502 \u1514 \u1493 \u1499 \u1504 \u1503  \u1513 \u1500  \u1492 \u1513 \u1497 \u1504 \u1493 \u1497 .
