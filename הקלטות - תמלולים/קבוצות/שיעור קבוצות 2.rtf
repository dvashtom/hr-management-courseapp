\cb3 \uc0\u1502 \u1500 \u1489 \u1491  \u1492 \u1513 \u1488 \u1500 \u1492  \u1488 \u1497 \u1498  \u1488 \u1504 \u1495 \u1504 \u1493  \u1514 \u1493 \u1508 \u1505 \u1497 \u1501  \u1488 \u1514  \u1492 \u1514 \u1508 \u1511 \u1497 \u1491  \u1493 \u1488 \u1497 \u1498  \u1492 \u1514 \u1508 \u1511 \u1497 \u1491  \u1492 \u1494 \u1492  \u1510 \u1512 \u1497 \u1498  \u1500 \u1492 \u1514 \u1504 \u1492 \u1500 , \u1497 \u1513  \u1500 \u1504 \u1493  \u1489 \u1506 \u1510 \u1501  \u1488 \u1514  \u1502 \u1492  \u1513 \u1504 \u1511 \u1512 \u1488  
