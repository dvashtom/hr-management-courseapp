\f1\b0 . \uc0\u1494 \u1492  \u1502 \u1510 \u1489  \u1513 \u1497 \u1513  \u1500 \u1497  \u1513 \u1514 \u1497  \u1514 \u1508 \u1497 \u1505 \u1493 \u1514  \u1513 \u1502 \u1504 \u1493 \u1490 \u1491 \u1493 \u1514  \u1500 \u1514 \u1508 \u1511 \u1497 \u1491  \u1493 \u1492 \u1503  \u1502 \u1514 \u1504 \u1490 \u1513 \u1493 \u1514 . \u1500 \u1502 \u1513 \u1500 , \u1499 \u1513 \u1488 \u1504 \u1497  \u1510 \u1512 \u1497 \u1499 \u1492  \u1500 \u1510 \u1493 \u1512 \u1498  \u1492 \u1506 \u1504 \u1497 \u1497 \u1503  \u1500 \u1495 \u1493 \u1508 \u1507  \u1499 \u1500 \u1500  \u1488 \u1493  \u1504 \u1493 \u1506 \u1500  \u1499 \u1491 \u1497  \u1500 \u1489 \u1510 \u1506  \u1492 \u1502 \u1513 \u1497 \u1502 \u1492 , \u1488 \u1493  \u1499 \u1513 \u1488 \u1504 \u1497  \u1510 \u1512 \u1497 \u1499 \u1492  \u1500 \u1489 \u1510 \u1506  \u1502 \u1492  \u1502 \u1513 \u1492 \u1493  \u1502 \u1488 \u1493 \u1491  \u1502 \u1492 \u1512  \u1493 \u1502 \u1488 \u1493 \u1491  \u1502 \u1491 \u1493 \u1497 \u1511 , \u1488 \u1493  \u1499 \u1513 \u1488 \u1504 \u1497  \u1502 \u1489 \u1511 \u1513 \u1514  \u1500 \u1502 \u1513 \u1500  \u1506 \u1500  \u1489 \u1511 \u1513 \u1493 \u1514  \u1505 \u1493 \u1514 \u1512 \u1493 \u1514  \u1502 \u1513 \u1504 \u1497 \u1497 \u1501  \u1488 \u1493  \u1502 \u1497 \u1493 \u1514 \u1512  \u1488 \u1504 \u1513 \u1497 \u1501 , \u1489 \u1505 \u1491 \u1512 ? \u1499 \u1513 \u1488 \u1504 \u1495 \u1504 \u1493  \u1504 \u1502 \u1510 \u1488 \u1497 \u1501  \u1489 \u1502 \u1510 \u1489  \u1499 \u1494 \u1492 , \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1499 \u1497 \u1512 \u1497 \u1501  \u1489 \u1505 \u1508 \u1512 \u1493 \u1514  \u1492 \u1502 \u1495 \u1511 \u1512 \u1497 \u1514  \u1513 \u1488 \u1504 \u1513 \u1497 \u1501  \u1513 \u1504 \u1502 \u1510 \u1488 \u1497 \u1501  \u1489 \u1511 \u1493 \u1504 \u1508 \u1500 \u1497 \u1511 \u1496  \u1492 \u1514 \u1508 \u1511 \u1497 \u1491 \u1497 \u1501  \u1505 \u1496 \u1512 \u1497 \u1501  \u1504 \u1502 \u1510 \u1488 \u1497 \u1501  \u1489 \u1492 \u1512 \u1489 \u14