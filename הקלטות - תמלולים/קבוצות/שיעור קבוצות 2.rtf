\cb3 \uc0\u1489 \u1514 \u1508 \u1497 \u1505 \u1514  \u1514 \u1508 \u1511 \u1497 \u1491  \u1488 \u1504 \u1495 \u1504 \u1493  \u1489 \u1506 \u1510 \u1501  \u1502 \u1491 \u1489 \u1512 \u1497 \u1501  \u1506 \u1500  \u1492 \u1505 \u1493 \u1490 \u1497 \u1492  \u1513 \u1489 \u1492  \u1488 \u1504 \u1495 \u1504 \u1493  \u1514 \u1493 \u1508 \u1505 \u1497 \u1501  \u1488 \u1514  \u1492 \u1491 \u1512 \u1498  \u1513 \u1489 \u1493  \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1488 \u1502 \u1497 \u1504 \u1497 \u1501  \u1513 \u1499 \u1498  \u1499 \u1498  \u1510 \u1512 \u1497 \u1498  \u1500 \u1492 \u1514 \u1504 \u1492 \u1490  \u1489  \u1514 \u1508 \u1511 \u1497 \u1491  \u1502 \u1505 \u1493 \u1497 \u1501 . \u1500 \u1502 \u1513 \u1500 , \u1489 \u1504 \u1497 \u1505 \u1493 \u1497  \u1513 \u1500  \u1494 \u1497 \u1502 \u1489 \u1512 \u1491 \u1493 , \u1492 \u1506 \u1505 \u1497 \u1512 \u1497 \u1501  \u1492 \u1514 \u1504 \u1492 \u1500 \u1493  \u1489 \u1491 \u1512 \u1498  \u1513 \u1492 \u1501  \u1492 \u1490 \u1491 \u1497 \u1512 \u1493  \u1500 \u1506 \u1510 \u1502 \u1501  \u1488 \u1514  \u1492 \u1514 \u1508 \u1511 \u1497 \u1491  \'97 \u1488 \u1497 \u1498  \u1510 \u1512 \u1497 \u1498  \u1500 \u1492 \u1514 \u1504 \u1492 \u1490  \u1492 \u1505 \u1497 \u1512  \u1493 \u1499 \u1498  \u1489 \u1506 \u1510 \u1501  \u1492 \u1501  \u1492 \u1514 \u1504 \u1492 \u1490 \u1493 . \u1488 \u1493 \u1514 \u1493  \u1491 \u1489 \u1512  \u1506 \u1513 \u1493  \u1492 \u1505 \u1493 \u1506 \u1512 \u1497 \u1501  \u1500 \u1490 \u1489 \u1497  \u1492 \u1514 \u1508 \u1511 \u1497 \u1491  \u1513 \u1500  \u1492 \u1505 \u1493 \u1506 \u1512 \u1497 \u1501 ."\cb1 \
