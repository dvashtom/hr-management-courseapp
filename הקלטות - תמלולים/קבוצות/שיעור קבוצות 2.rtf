\f0\b \uc0\u1505 \u1496 \u1496 \u1493 \u1505 
\f1\b0 . \uc0\u1499 \u1513 \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1491 \u1489 \u1512 \u1497 \u1501  \u1506 \u1500  \u1505 \u1496 \u1496 \u1493 \u1505 , \u1488 \u1504 \u1495 \u1504 \u1493  \u1489 \u1506 \u1510 \u1501  \u1496 \u1493 \u1506 \u1504 \u1497 \u1501  \u1513 \u1489 \u1491  \u1514 \u1508 \u1511 \u1497 \u1491 \u1497 \u1501  \u1513 \u1493 \u1504 \u1497 \u1501  \u1497 \u1513  \u1500 \u1504 \u1493  \u1490 \u1501  \u1505 \u1496 \u1496 \u1493 \u1505  \u1513 \u1493 \u1504 \u1492  \u1489 \u1495 \u1489 \u1512 \u1497 \u1501  \u1492 \u1513 \u1493 \u1504 \u1497 \u1501  \u1513 \u1497 \u1513  \u1500 \u1504 \u1493  \u1489 \u1511 \u1493 \u1512 \u1510 \u1492 . \u1492 \u1505 \u1496 \u1496 \u1493 \u1505  \u1492 \u1494 \u1492  \u1504 \u1490 \u1494 \u1512  \u1502 \u1497 \u1493 \u1511 \u1512 \u1492 , \u1502 \u1499 \u1489 \u1493 \u1491  \u1493 \u1492 \u1506 \u1512 \u1499 \u1492  \u1513 \u1508 \u1512 \u1496  \u1502 \u1511 \u1489 \u1500  \u1502 \u1492 \u1511 \u1489 \u1493 \u1510 \u1492 . \u1497 \u1513  \u1500 \u1504 \u1493  \u1488 \u1504 \u1513 \u1497 \u1501  \u1506 \u1501  \u1505 \u1496 \u1496 \u1493 \u1505  \u1490 \u1489 \u1493 \u1492 , \u1497 \u1513  \u1500 \u1504 \u1493  \u1488 \u1504 \u1513 \u1497 \u1501  \u1506 \u1501  \u1505 \u1496 \u1496 \u1493 \u1505  \u1489 \u1497 \u1504 \u1493 \u1504 \u1497 , \u1497 \u1513  \u1500 \u1504 \u1493  \u1488 \u1504 \u1513 \u1497 \u1501  \u1506 \u1501  \u1505 \u1496 \u1496 \u1493 \u1505  \u1504 \u1502 \u1493 \u1498 ."\cb1 \
\cb3 "\uc0\u1499 \u1513 \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1505 \u1514 \u1499 \u1500 \u1497 \u1501  \u1506 \u1500  \u1488 \u1504 \u1513 \u1497 \u1501  \u1513 \u1497 \u1513  \u1500 \u1492 \u1501  \u1505 \u1496 \u1496 \u1493 \u1505  \u1490 \u1489 \u1493 \u1492  \u1493 \u1502 \u1506 \u1504 \u1497 \u1497 \u1503  \u1500 \u1489 \u1495 \u1493 \u1503  \u1500 \u1502 \u1492  \u1492 \u1501  \u1511 \u1497 \u1489 \u1500 \u1493  \u1488 \u1514  \u1492 \u1505 \u1496 \u1496 \u1493 \u1505  \u1492 \u1490 \u1489 \u1493 \u1492  \u1492 \u1494 \u1492 , \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1493 \u1510 \u1488 \u1497 \u1501  \u1513 \u1502 \u1506 \u1500 \u1497  \u1505 \u1496 \u1496 \u1493 \u1505  \u1490 \u1489 \u1493 \u1492  \u1502 \u1512 \u1513 \u1497 \u1501  \u1500 \u1506 \u1510 \u1502 \u1501  \u1488  \u1500 \u1492 \u1514 \u1506 \u1512 \u1489 , \u1500 \u1492 \u1506 \u1489 \u1497 \u1512  \u1489 \u1497 \u1511 \u1493 \u1512 \u1514 , \u1504 \u1493 \u1496 \u1500 \u1497 \u1501  \u1488 \u1514  \u1512 \u1513 \u1493 \u1514  \u1492 \u1491 \u1497 \u1489 \u1493 \u1512 , \u1488 \u1493 \u1492 \u1489 \u1497 \u1501  \u1500 \u1491 \u1489 \u1512  \u1492 \u1512 \u1489 \u1492  \u1494 \u1502 \u1503  \u1502 \u1506 \u1489 \u1512  \u1500 \u1494 \u1502 \u1503  \u1513 \u1502 \u1493 \u1511 \u1510 \u1489  \u1500 \u1513 \u1488 \u1512  \u1495 \u1489 \u1512 \u1497  \u1492 \u1511 \u1489 \u1493 \u1510 \u1492 , \u1513 \u1493 \u1500 \u1496 \u1497 \u1501  \u1502 \u1488 \u1493 \u1491  \u1506 \u1500  \u1511 \u1489 \u1500 \u1514  \u1492 \u1492 \u1495 \u1500 \u1496 \u1493 \u1514  \u1493 \u1492 \u1491 \u1512 \u1498  \u1513 \u1489 \u1492  \u1502 \u1514 \u1504 \u1492 \u1500 \u1514  \u1499 \u1500  \u1492  \u1499 \u1500  \u1492 \u1492 \u1495 \u1500 \u1496 \u1492  \u1493 \u1499 \u1500  \u1492 \u1492 \u1514 \u1504 \u1492 \u1500 \u1493 \u1514  \u1492 \u1512 \u1490 \u1497 \u1500 \u1492 . \u1493 \u1492 \u1512 \u1489 \u1492  \u1508 \u1506 \u1502 \u1497 \u1501  \u1492 \u1501  \u1490 \u1501  \u1502 \u1511 \u1489 \u1500 \u1497 \u1501  \u1514 \u1490 \u1502 \u1493 \u1500 \u1497 \u1501  \u1512 \u1489 \u1497 \u1501  \u1497 \u1493 \u1514 \u1512 . \u1499 \u1513 \u1488 \u1504 \u1497  \u1502 \u1491 \u1489 \u1512 \u1514  \u1506 \u1500  \u1514 \u1490 \u1502 \u1493 \u1500 \u1497 \u1501  \u1488 \u1504 \u1497  \u1500 \u1488  \u1491 \u1493 \u1493 \u1511 \u1488  \u1502 \u1491 \u1489 \u1512 \u1514  \u1506 \u1500  \u1499 \u1505 \u1507 . \u1494 \u1492  \u1497 \u1499 \u1493 \u1500  \u1500 \u1492 \u1497 \u1493 \u1514  \u1490 \u1501  \u1499 \u1502 \u1493 \u1489 \u1503  \u1514 \u1490 \u1502 \u1493 \u1500 \u1497 \u1501  \u1489 \u1502 \u1493 \u1489 \u1504 \u1497 \u1501  \u1513 \u1500  \u1495 \u1491 \u1512  \u1497 \u1493 \u1514 \u1512  \u1490 \u1491 \u1493 \u1500 , \u1504 \u1506 \u1497 \u1501  \u1497 \u1493 \u1514 \u1512  \u1496 \u1493 \u1489 \u1497 \u1501 , \u1493 \u1494 \u1492  \u1495 \u1500 \u1511  \u1502 \u1492 \u1492 \u1490 \u1491 \u1512 \u1492  \u1513 \u1500 \u1492 \u1501  \u1499 \u1489 \u1506 \u1500 \u1497  \u1505 \u1496 \u1496 \u1493 \u1505  \u1490 \u1489 \u1493 \u1492  \u1497 \u1493 \u1514 \u1512 .\cb1 \
\cb3 \uc0\u1500 \u1508 \u1504 \u1497  \u1513 \u1488 \u1504 \u1495 \u1504 \u1493  \u1504 \u1508 \u1512 \u1491 \u1497 \u1501  \u1500 \u1502 \u1508 \u1490 \u1513  \u1492 \u1502 \u1511 \u1493 \u1493 \u1503 , \u1488 \u1504 \u1497  \u1502 \u1489 \u1511 \u1513 \u1514  \u1513 \u1514 \u1495 \u1513 \u1489 \u1493 , \u1499 \u1502 \u1493  \u1513 \u1513 \u1488 \u1500 \u1514 \u1497  \u1511 \u1493 \u1491 \u1501 , 
\f0\b \uc0\u1502 \u1492  \u1492 \u1493 \u1508 \u1498  \u1488 \u1504 \u1513 \u1497 \u1501  \u1489 \u1514 \u1493 \u1498  \u1511 \u1489 \u1493 \u1510 \u1492  \'97 \u1489 \u1514 \u1493 \u1498  \u1511 \u1489 \u1493 \u1510 \u1514  \u1506 \u1489 \u1493 \u1491 \u1492  \'97 \u1500 \u1489 \u1506 \u1500 \u1497  \u1505 \u1496 \u1496 \u1493 \u1505  \u1490 \u1489 \u1493 \u1492 ?
\f1\b0  \uc0\u1493 \u1488 \u1501  \u1499 \u1513 \u1488 \u1504 \u1497  \u1502 \u1491 \u1489 \u1512 \u1514  \u1506 \u1500  \u1489 \u1506 \u1500 \u1497  \u1505 \u1496 \u1496 \u1493 \u1505  \u1490 \u1489 \u1493 \u1492 , \u1488 \u1504 \u1495 \u1504 \u1493  \u1489 \u1506 \u1510 \u1501  \u1502 \u1491 \u1489 \u1512 \u1497 \u1501  \u1512 \u1511  \u1506 \u1500  \u1502 \u1504 \u1492 \u1500  \u1488 \u1493  \u1502 \u1504 \u1492 \u1500 \u1514 ? \u1502 \u1497  \u1506 \u1493 \u1491  \u1497 \u1499 \u1493 \u1500  \u1500 \u1492 \u1497 \u1493 \u1514  \u1489 \u1514 \u1493 \u1498  \u1511 \u1489 \u1493 \u1510 \u1492  \u1506 \u1501  \u1505 \u1496 \u1496 \u1493 \u1505  \u1490 \u1489 \u1493 \u1492 ? \u1488 \u1504 \u1495 \u1504 \u1493  \u1502 \u1505 \u1497 \u1497 \u1502 \u1497 \u1501  \u1488 \u1514  \u1492 \u1495 \u1500 \u1511  \u1492 \u1513 \u1504 \u1497 ."\cb1 \
