\f0\b \cf2 \cb3 \uc0\u1502 \u1488 \u1494  \u1513 \u1492 \u1505 \u1514 \u1497 \u1497 \u1502 \u1493  \u1492 \u1510 \u1497 \u1500 \u1493 \u1502 \u1497 \u1501 , \u1492 \u1500 \u1495 \u1509  \u1489 -EDS \u1513 \u1492 \u1514 \u1502 \u1494 \u1490 \u1492  \u1506 \u1501  HP \u1512 \u1511  \u1492 \u1500 \u1498  \u1493 \u1490 \u1489 \u1512 . \u1492 \u1497 \u1493  \u1490 \u1501  \u1500 \u1488  \u1502 \u1506 \u1496  \u1508 \u1497 \u1496 \u1493 \u1512 \u1497 \u1501  \'97 \u1500 \u1488  \u1513 \u1500  \u1495 \u1497 \u1497 \u1501 , \u1492 \u1493 \u1488  \u1491 \u1493 \u1493 \u1511 \u1488  \u1513 \u1512 \u1491  \u1488 \u1514  \u1492 \u1502 \u1513 \u1489 \u1512  \u1493 \u1488 \u1508 \u1497 \u1500 \u1493  \u1511 \u1497 \u1489 \u1500  \u1508 \u1512 \u1493 \u1497 \u1511 \u1496  \u1495 \u1491 \u1513  \u1488 \u1510 \u1500  \u1488 \u1500 \u1506 \u1491 .
