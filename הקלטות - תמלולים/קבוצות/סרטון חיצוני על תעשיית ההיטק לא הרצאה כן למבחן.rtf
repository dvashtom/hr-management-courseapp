\f0\b\fs24 \cf2 \cb3 \strokec2 \uc0\u1495 \u1500 \u1511  5: \u1511 \u1513 \u1497 \u1497 \u1501  \u1499 \u1500 \u1499 \u1500 \u1497 \u1497 \u1501 , \u1489 \u1504 \u1497 \u1497 \u1514  \u1492 \u1489 \u1497 \u1514  \u1493 \u1492 \u1514 \u1502 \u1493 \u1491 \u1491 \u1493 \u1514  \u1506 \u1501  \u1500 \u1495 \u1510 \u1497  \u1502 \u1500 \u1497  \u1511 \u1493 \u1489 \u1497 \cb1 \
\pard\pardeftab720\partightenfactor0

\f1\b0\fs32 \cf2 \cb3 "\uc0\u1488 \u1492 , \u1500 \u1497 \u1506 \u1491 , \u1488 \u1504 \u1497  \u1499 \u1489 \u1512  \u1495 \u1493 \u1494 \u1512 \u1514  \u1488 \u1500 \u1497 \u1498 , \u1488 \u1504 \u1497  \u1495 \u1497 \u1497 \u1489 \u1514  \u1500 \u1506 \u1513 \u1493 \u1514  \u1506 \u1493 \u1491  \u1508 \u1506 \u1501  \u1489 \u1489 \u1497 \u1514 ". "\u1488 \u1493 \u1511 \u1497 \u1497 , \u1514 \u1495 \u1513 \u1489 \u1493  \u1513 \u1497 \u1513  \u1500 \u1504 \u1493  10 \u1491 \u1511 \u1493 \u1514 , \u1488 \u1504 \u1497  \u1512 \u1493 \u1510 \u1492 ...". "\u1488 \u1502 \u1497 \u1512 ?". "\u1499 \u1503 ". "\u1492 \u1497 \u1497 , \u1488 \u1514 \u1492  \u1513 \u1493 \u1502 \u1506 ? \u1497 \u1513  \u1500 \u1504 \u1493  \u1506 \u1499 \u1513 \u1497 \u1493  \u1511 \u1512 \u1497 \u1505 \u1497 \u1505  \u1508 \u1492  \u1489 \u1506 \u1489 \u1493 \u1491 \u1492  \u1493 \u1500 \u1488  \u1504 \u1512 \u1488 \u1492  \u1500 \u1497  \u1513 \u1488 \u1504 \u1497  \u1488 \u1493 \u1499 \u1500  \u1500 \u1510 \u1488 \u1514  \u1512 \u1490 \u1497 \u1500 ". 
\f0\b \uc0\u1488 \u1497 \u1492  \u1504 \u1502 \u1510 \u1488 \u1514  \u1489 \u1495 \u1493 \u1491 \u1513  \u1492 \u1513 \u1489 \u1497 \u1506 \u1497  \u1500 \u1492 \u1512 \u1497 \u1493 \u1504 \u1492 , \u1504 \u1513 \u1493 \u1488 \u1492  \u1500 \u1488 \u1502 \u1497 \u1512 , \u1493 \u1497 \u1513  \u1500 \u1492 \u1501  \u1513 \u1504 \u1497  \u1497 \u1500 \u1491 \u1497 \u1501  \u1493 \u1492 \u1501  \u1490 \u1512 \u1497 \u1501  \u1489 \u1489 \u1497 \u1514  \u1502 \u1508 \u1493 \u1488 \u1512  \u1513 \u1489 \u1504 \u1493  \u1500 \u1488 \u1495 \u1512 \u1493 \u1504 \u1492  \u1489 \u1502 \u1493 \u1513 \u1489  \u1497 \u1493 \u1511 \u1512 \u1514 \u1497  \u1489 \u1513 \u1512 \u1493 \u1503 .
\f1\b0  "\uc0\u1490 \u1501  \u1514 \u1510 \u1496 \u1512 \u1498  \u1488 \u1492  \u1500 \u1492 \u1495 \u1500 \u1497 \u1507  \u1488 \u1493 \u1514 \u1497  \u1493 \u1490 \u1501  \u1500 \u1489 \u1496 \u1500  \u1488 \u1514  \u1492 \u1490 \u1504 \u1504 \u1497 \u1514 , \u1489 \u1505 \u1491 \u1512 ?". "\u1499 \u1502 \u1492  \u1494 \u1502 \u1503  \u1488 \u1514 \u1501  \u1499 \u1489 \u1512  \u1508 \u1492 ?". "\u1513 \u1504 \u1492 ". "\u1494 \u1492  \u1488 \u1502 \u1497 \u1512  \u1506 \u1513 \u1492  \u1499 \u1491 \u1497  \u1513 \u1489 \u1490 \u1513 \u1501  \u1500 \u1488  \u1497 \u1500 \u1499 \u1493  \u1489 \u1514 \u1493 \u1498  \u1492 \u1513 \u1500 \u1493 \u1500 \u1497 \u1514 ". "\u1500 \u1502 \u1492  \u1494 \u1492  \u1499 \u1499 \u1492 ?". "\u1504 \u1490 \u1502 \u1512  \u1492 \u1499 \u1505 \u1507 . \u1494 \u1492  \u1500 \u1502 \u1492 ". \u1492 \u1490 \u1497 \u1504 \u1492 , \u1502 \u1514 \u1489 \u1512 \u1512 , \u1492 \u1497 \u1488  \u1500 \u1488  \u1492 \u1491 \u1489 \u1512  \u1492 \u1497 \u1495 \u1497 \u1491  \u1513 \u1502 \u1514 \u1506 \u1499 \u1489  \u1489 \u1489 \u1497 \u1514  \u1492 \u1495 \u1500 \u1493 \u1502 \u1493 \u1514  \u1513 \u1500  \u1488 \u1502 \u1497 \u1512  \u1493 \u1488 \u1497 \u1492 . \u1489 \u1490 \u1500 \u1500  \u1492 \u1502 \u1513 \u1489 \u1512  \u1492 \u1499 \u1500 \u1499 \u1500 \u1497  \u1492 \u1501  \u1490 \u1497 \u1500 \u1493  \u1513 \u1497 \u1513  \u1489 \u1493 \u1512  \u1489 \u1514 \u1511 \u1510 \u1497 \u1489  \u1493 \u1492 \u1489 \u1504 \u1497 \u1497 \u1492  \u1504 \u1506 \u1510 \u1512 \u1492  \u1506 \u1491  \u1513 \u1492 \u1513 \u1497 \u1490 \u1493  \u1502 \u1497 \u1502 \u1493 \u1503  \u1504 \u1493 \u1505 \u1507 .\cb1 \
\cb3 "\uc0\u1488 \u1494  \u1502 \u1492 , \u1497 \u1513  \u1505 \u1497 \u1499 \u1493 \u1497  \u1513 \u1494 \u1492  \u1497 \u1495 \u1499 \u1492  \u1490 \u1501  \u1492 \u1513 \u1504 \u1492 ?". "\u1488 \u1514 \u1492  \u1512 \u1493 \u1510 \u1492  \u1488 \u1514  \u1494 \u1492 ? \u1488 \u1514 \u1492  \u1512 \u1493 \u1510 \u1492  \u1488 \u1514  \u1494 \u1492  \u1506 \u1501  \u1492 \u1488 \u1490 \u1493 \u1494  \u1492 \u1494 \u1492  \u1490 \u1501  \u1506 \u1499 \u1513 \u1497 \u1493 ?". "\u1499 \u1503 , \u1502 \u1492  \u1500 \u1511 \u1495 \u1514  \u1500 \u1502 \u1512 \u1493 \u1514  \u1492 \u1502 \u1510 \u1489 ? \u1500 \u1511 \u1495 \u1514  \u1506 \u1493 \u1491  \u1488 \u1497 \u1494 \u1492  \u1492 \u1514 \u1495 \u1497 \u1497 \u1489 \u1493 \u1514 ?". "\u1494 \u1492  \u1492 \u1499 \u1500  \u1494 \u1492  \u1494 \u1492  \u1492 \u1514 \u1495 \u1497 \u1497 \u1489 \u1493 \u1514 , \u1499 \u1503 , \u1488 \u1489 \u1500  \u1500 \u1488 ...". 
\f0\b \uc0\u1488 \u1497 \u1492  \u1489 \u1506 \u1510 \u1501  \u1504 \u1502 \u1510 \u1488 \u1514  \u1489 \u1488 \u1497 \u1494 \u1493 \u1513 \u1492 \u1497  \u1514 \u1495 \u1493 \u1513 \u1492  \u1513 \u1500  \u1502 \u1500 \u1511 \u1493 \u1491  \u1513 \u1488 \u1501  \u1492 \u1501  \u1500 \u1488  \u1497 \u1513 \u1497 \u1502 \u1493  \u1488 \u1514  \u1499 \u1500  \u1492 \u1488 \u1504 \u1512 \u1490 \u1497 \u1492  \u1493 \u1492 \u1490 \u1494  \u1489 \u1506 \u1513 \u1497 \u1497 \u1514  \u1492 \u1499 \u1505 \u1507 , \u1492 \u1501  \u1497 \u1508 \u1505 \u1497 \u1491 \u1493  \u1488 \u1514  \u1502 \u1492  \u1513 \u1489 \u1506 \u1510 \u1501  \u1492 \u1501  \u1492 \u1514 \u1495 \u1497 \u1500 \u1493 .
