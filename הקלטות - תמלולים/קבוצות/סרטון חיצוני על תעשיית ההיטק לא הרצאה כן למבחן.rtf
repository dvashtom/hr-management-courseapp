\f0\b \cf2 \cb3 \uc0\u1500 \u1508 \u1504 \u1497  \u1492 \u1500 \u1497 \u1491 \u1492 , \u1488 \u1500 \u1493 \u1504 \u1492  \u1506 \u1489 \u1491 \u1492  \u1489 \u1502 \u1513 \u1512 \u1492  \u1489 \u1499 \u1497 \u1512 \u1492  \u1489 \u1495 \u1489 \u1512 \u1514  \u1492 \u1497 \u1497 \u1496 \u1511 , \u1488 \u1489 \u1500  \u1506 \u1499 \u1513 \u1497 \u1493 , \u1489 \u1504 \u1497 \u1490 \u1493 \u1491  \u1500 \u1506 \u1502 \u1491 \u1514 \u1493  \u1513 \u1500  \u1502 \u1493 \u1496 \u1497 , \u1492 \u1497 \u1488  \u1502 \u1495 \u1500 \u1497 \u1496 \u1492  \u1500 \u1495 \u1494 \u1493 \u1512  \u1500 \u1513 \u1493 \u1511  \u1492 \u1506 \u1489 \u1493 \u1491 \u1492  \u1512 \u1511  \u1500 \u1502 \u1513 \u1512 \u1492  \u1495 \u1500 \u1511 \u1497 \u1514 , \u1499 \u1491 \u1497  \u1513 \u1500 \u1497 \u1500 \u1491 \u1497 \u1501  \u1497 \u1492 \u1497 \u1492  \u1500 \u1508 \u1495 \u1493 \u1514  \u1492 \u1493 \u1512 \u1492  \u1488 \u1495 \u1491  \u1489 \u1504 \u1502 \u1510 \u1488 .
\f1\b0  "\uc0\u1494 \u1488 \u1514  \u1488 \u1493 \u1502 \u1512 \u1514 , \u1494 \u1492  \u1513 \u1488 \u1504 \u1497  \u1506 \u1499 \u1513 \u1497 \u1493  \u1502 \u1495 \u1508 \u1513 \u1514  \u1502 \u1513 \u1512 \u1492  \u1513 \u1492 \u1497 \u1488  \u1500 \u1488  \u1502 \u1500 \u1488 \u1492  \u1499 \u1491 \u1497  \u1500 \u1488  \u1500 \u1495 \u1494 \u1493 \u1512  \u1489 \u1513 \u1513 -\u1513 \u1489 \u1506  \u1492 \u1489 \u1497 \u1514 \u1492 , \u1488 \u1494  \u1494 \u1492  \u1502 \u1489 \u1495 \u1497 \u1512 \u1492 ". "\u1488 \u1489 \u1500  \u1502 \u1493 \u1496 \u1497  \u1488 \u1502 \u1512  \u1513 \u1500 \u1488 , \u1492 \u1493 \u1488  \u1492 \u1497 \u1492  \u1502 \u1506 \u1491 \u1497 \u1507  \u1513 \u1514 \u1506 \u1489 \u1491 \u1497  \u1502 \u1513 \u1512 \u1492  \u1502 \u1500 \u1488 \u1492 ". "\u1492 \u1493 \u1488  \u1492 \u1497 \u1492  \u1512 \u1493 \u1510 \u1492  \u1499 \u1497  \u1492 \u1493 \u1488  \u1502 \u1488 \u1493 \u1491  \u1502 \u1508 \u1495 \u1491  \u1513 \u1497 \u1508 \u1490 \u1506  \u1500 \u1497  \u1489 \u1511 \u1512 \u1497 \u1497 \u1512 \u1492 . \u1502 \u1489 \u1495 \u1497 \u1512 \u1492  \u1492 \u1495 \u1500 \u1496 \u1514 \u1497  \u1513 \u1499 \u1512 \u1490 \u1506  \u1488 \u1504 \u1497  \u1500 \u1488  \u1512 \u1493 \u1510 \u1492  \u1489 \u1508 \u1493 \u1500 -\u1496 \u1497 \u1497 \u1501 , \u1488 \u1504 \u1497  \u1499 \u1503  \u1512 \u1493 \u1510 \u1492  \u1500 \u1492 \u1497 \u1493 \u1514  \u1489 \u1489 \u1497 \u1514  \u1497 \u1493 \u1514 \u1512  \u1488 \u1497 \u1514 \u1501 . \u1494 \u1492  \u1499 \u1497 \u1507  \u1500 \u1492 \u1501  \u1513 \u1497 \u1513  \u1492 \u1493 \u1512 \u1492  \u1489 \u1489 \u1497 \u1514  \u1513 \u1500 \u1493 \u1511 \u1495  \u1488 \u1493 \u1514 \u1501 , \u1513 \u1502 \u1499 \u1497 \u1503  \u1488 \u1497 \u1514 \u1501  \u1513 \u1497 \u1506 \u1493 \u1512 \u1497 \u1501 ...". "\u1493 \u1493 \u1488 \u1497 , \u1508 \u1505 \u1508 \u1505 \u1514 \u1497  \u1500 \u1498  \u1488 \u1514  \u1492 \u1495 \u1493 \u1490  \u1492 \u1497 \u1493 \u1501  \u1495